generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  carts     Cart[]
  orders    Order[]
  products  Product[]
}

model Product {
  id          String      @id @default(cuid())
  shopId      String
  title       String
  description String?
  price       Float
  imageUrl    String?
  stock       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  cartItems   CartItem[]
  orderItems  OrderItem[]
  shop        Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model Order {
  id        String      @id @default(cuid())
  shopId    String
  total     Float
  createdAt DateTime    @default(now())
  shop      Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items     OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Float
  productId String
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Cart {
  id        String     @id @default(cuid())
  shopId    String
  sessionId String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  shop      Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  cartItems CartItem[]

  @@unique([sessionId, shopId])
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  quantity  Int     @default(1)
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}
